# E-ITS Management System - Production Environment Template
# Copy to .env on the server and fill in values.
# Run: openssl rand -hex 32  to generate secrets.

APP_ENV=staging
APP_NAME=eits-cyberplan

# PostgreSQL
POSTGRES_DB=eits
POSTGRES_USER=eits
POSTGRES_PASSWORD=change-me-please-use-openssl-rand-hex-32

DATABASE_URL=postgresql+psycopg://eits:change-me-please-use-openssl-rand-hex-32@postgres:5432/eits

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (Object Storage)
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=<VPS_IP>:9000
MINIO_ACCESS_KEY=change-me-please-use-openssl-rand-hex-16
MINIO_SECRET_KEY=change-me-please-use-openssl-rand-hex-32
MINIO_BUCKET=eits-evidence
MINIO_SECURE=false

# JWT / Authentication
JWT_SECRET_KEY=change-me-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Frontend (build arg)
VITE_API_URL=/api/v2

# CORS - list the origins that may access the API
BACKEND_CORS_ORIGINS=http://<VPS_IP>:5071

# Logging
LOG_LEVEL=INFO
