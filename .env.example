# E-ITS Management System - Environment Variables
# Copy this file to .env and fill in values for your local environment.

APP_ENV=local
APP_NAME=eits-management-system

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=eits
POSTGRES_USER=eits
POSTGRES_PASSWORD=eits_dev_password

DATABASE_URL=postgresql+psycopg://eits:eits_dev_password@postgres:5432/eits

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (Object Storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eits-evidence
MINIO_SECURE=false

# JWT / Authentication
JWT_SECRET_KEY=change-me-in-local-only-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Frontend
VITE_API_URL=/api/v2

# E-ITS Catalog ETL
EITS_IMPORT_YEAR=2024
EITS_SOURCE_URL=https://eits.ria.ee/api/2/article/asset/2024/E-ITS%202024_meetmete_tabel_CC.xlsx

# CORS
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO